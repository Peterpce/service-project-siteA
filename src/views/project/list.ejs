<%- include("../partials/header", { title: title }) %>

<main class="container">

  <section class="page-header">
    <h1>Service Projects</h1>
    <p>Explore ongoing and upcoming service opportunities you can participate in.</p>

    <a href="/projects/create" class="btn">+ Add Project</a>
  </section>

  <section class="card-grid">

    <% if (projects && projects.length > 0) { %>

      <% projects.forEach(project => { %>

        <div class="card">

          <h2><%= project.name %></h2>

          <p><%= project.description %></p>

          <div style="margin-top: 1rem; display: flex; gap: 0.75rem;">
            <a href="/projects/<%= project.id %>">View</a>
            <span style="color: #ccc;">|</span>
            <a href="/projects/edit/<%= project.id %>">Edit</a>
          </div>

        </div>

      <% }) %>

    <% } else { %>

      <p style="grid-column: 1 / -1; text-align: center; color: #666;">No projects available yet.</p>

    <% } %>

  </section>

</main>

<%- include("../partials/footer") %>