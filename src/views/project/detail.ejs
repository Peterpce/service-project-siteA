<%- include("../partials/header", { title: title }) %>

<main class="container">

  <section class="page-header">
    <h1><%= project.name %></h1>
    <p>Project Details</p>
  </section>

  <section class="detail-card">

    <h2>Description</h2>
    <p><%= project.description %></p>

    <h3>Assigned Categories</h3>

    <% if (categories && categories.length > 0) { %>
      <ul>
        <% categories.forEach(category => { %>
          <li><%= category.name %></li>
        <% }) %>
      </ul>
    <% } else { %>
      <p>No categories assigned yet.</p>
    <% } %>

  </section>

  <!-- ========================= -->
  <!-- W06 VOLUNTEER FEATURE -->
  <!-- ========================= -->

  <section class="volunteer-section">

    <% if (user) { %>

      <% if (!isVolunteer) { %>

        <!-- VOLUNTEER BUTTON -->
        <form method="POST" action="/projects/<%= project.id %>/volunteer">
          <button type="submit" class="btn volunteer-btn">
            Volunteer for this Project
          </button>
        </form>

      <% } else { %>

        <p class="success-msg">
          You are volunteering for this project.
        </p>

        <!-- REMOVE VOLUNTEER BUTTON -->
        <form method="POST" action="/projects/<%= project.id %>/unvolunteer">
          <button type="submit" class="btn danger-btn">
            Remove Me as Volunteer
          </button>
        </form>

      <% } %>

    <% } else { %>

      <p>
        Please <a href="/login">log in</a> to volunteer for this project.
      </p>

    <% } %>

  </section>

  <!-- ACTION BUTTONS -->
  <section class="actions">

    <a href="/projects/edit/<%= project.id %>" class="btn">
      Edit Project
    </a>

    <a href="/projects/assign-category/<%= project.id %>" class="btn">
      Assign Categories
    </a>

    <a href="/projects" class="btn secondary">
      Back to Projects
    </a>

  </section>

</main>

<%- include("../partials/footer") %>