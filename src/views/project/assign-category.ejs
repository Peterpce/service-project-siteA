<%- include("../partials/header", { title: title }) %>

<main class="container">

  <section class="page-header">
    <h1>Assign Categories</h1>
    <p><%= project.name %></p>
  </section>

  <section class="form-container">

    <form action="/projects/assign-category/<%= project.id %>" method="POST">

      <h3>Select Categories</h3>

      <% categories.forEach(category => { %>

        <div class="checkbox-item" style="margin-bottom: 0.5rem;">

          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">

            <input
              type="checkbox"
              name="categories"
              value="<%= category.id %>"
              <% if (assignedCategories.includes(category.id)) { %> checked <% } %>
            >

            <%= category.name %>

          </label>

        </div>

      <% }) %>

      <div style="margin-top: 1.5rem; display: flex; gap: 1rem;">
        <button type="submit" class="btn">Save Assignments</button>
        <a href="/projects/<%= project.id %>" class="btn secondary">Cancel</a>
      </div>

    </form>

  </section>

</main>

<%- include("../partials/footer") %>