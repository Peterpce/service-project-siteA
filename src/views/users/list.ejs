<%- include('../partials/header') %>[cite: 13]

<h1>Registered Users</h1>[cite: 13]

<table border="1" cellpadding="10">[cite: 13]
  <thead>[cite: 13]
    <tr>[cite: 13]
      <th>ID</th>[cite: 13]
      <th>Name</th>[cite: 13]
      <th>Email</th>[cite: 13]
      <th>Role</th>[cite: 13]
    </tr>[cite: 13]
  </thead>[cite: 13]

  <tbody>[cite: 13]
    <% if (users && users.length > 0) { %>[cite: 13]
      <% users.forEach(user => { %>[cite: 13]
        <tr>[cite: 13]
          <td><%= user.id %></td>[cite: 13]
          <td><%= user.name %></td>[cite: 13]
          <td><%= user.email %></td>[cite: 13]
          <td><%= user.role %></td>[cite: 13]
        </tr>[cite: 13]
      <% }) %>[cite: 13]
    <% } else { %>[cite: 13]
      <tr>[cite: 13]
        <td colspan="4">No users found</td>[cite: 13]
      </tr>[cite: 13]
    <% } %>[cite: 13]
  </tbody>[cite: 13]
</table>[cite: 13]

<br />[cite: 13]

<a href="/dashboard">← Back to Dashboard</a>[cite: 13]

<%- include('../partials/footer') %>[cite: 13]