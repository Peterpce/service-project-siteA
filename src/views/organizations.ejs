<%- include("partials/header", { title: title }) %>

<main class="container">

    <section class="page-header">
        <h1>Organizations</h1>
        <p>
            Discover organizations dedicated to making a positive impact in communities.
        </p>
    </section>

    <section class="card-grid">

        <div class="card">
            <img src="/images/unityserve-logo.png" alt="Community volunteers helping others" width="30" height="80">
            <h2>Helping Hands Foundation</h2>
            <p>
                Focused on supporting families through education, outreach, and community programs.
            </p>
        </div>

        <div class="card">
            <img src="/images/greenharvest-logo.png" alt="Environmental cleanup activity" width="30" height="80">
            <h2>Green Earth Initiative</h2>
            <p>
                Dedicated to environmental protection, tree planting, and clean-up campaigns.
            </p>
        </div>

        <div class="card">
            <img src="/images/brightfuture-logo.png" alt="Youth learning program" width="30" height="80">
            <h2>Youth Empowerment Network</h2>
            <p>
                Helps young people develop skills through mentorship and training programs.
            </p>
        </div>

    </section>

</main>

<%- include("partials/footer") %>