<%- include('partials/header') %>

<div class="dashboard-container">

  <h1>Dashboard</h1>

  <p>Welcome, <strong><%= user?.name %></strong></p>
  <p>Email: <%= user?.email %></p>
  <p>Role: <%= user?.role %></p>

  <hr>

  <h2>Quick Links</h2>

  <ul>
    <li><a href="/organizations">Organizations</a></li>
    <li><a href="/projects">Projects</a></li>
    <li><a href="/categories">Categories</a></li>
  </ul>

  <% if (user?.role === "admin") { %>
    <hr>

    <h2>Admin Panel</h2>

    <ul>
      <li><a href="/users">Manage Users</a></li>
    </ul>
  <% } %>

  <hr>

  <!-- ========================= -->
  <!-- W06 VOLUNTEER SECTION -->
  <!-- ========================= -->

  <h2>My Volunteer Projects</h2>

  <% if (volunteerProjects && volunteerProjects.length > 0) { %>

    <ul>

      <% volunteerProjects.forEach(project => { %>

        <li>
          <strong><%= project.name %></strong>

          <!-- View project -->
          <a href="/projects/<%= project.id %>">View</a>

          <!-- Remove volunteer -->
          <form
            action="/projects/<%= project.id %>/unvolunteer"
            method="POST"
            style="display:inline;"
          >
            <button type="submit">Remove</button>
          </form>
        </li>

      <% }) %>

    </ul>

  <% } else { %>

    <p>You have not volunteered for any projects yet.</p>

  <% } %>

  <hr>

  <a href="/logout">Logout</a>

</div>

<%- include('partials/footer') %>