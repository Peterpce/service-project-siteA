<%- include("partials/header", { title: title }) %>

<main class="container">

    <section class="hero">
        <h1>Community Service Hub</h1>
        <p>
            Welcome to a platform where you can discover meaningful service opportunities,
            connect with organizations, and make a positive impact in your community.
        </p>

        <a href="/projects" class="btn">Explore Projects</a>
    </section>

    <section class="features">

        <div class="card-grid">

            <div class="card">
                <h2>Organizations</h2>
                <p>
                    Learn about organizations that are actively working to improve lives and communities.
                </p>
                <a href="/organizations">View Organizations</a>
            </div>

            <div class="card">
                <h2>Projects</h2>
                <p>
                    Explore ongoing and upcoming service projects you can participate in.
                </p>
                <a href="/projects">View Projects</a>
            </div>

            <div class="card">
                <h2>Categories</h2>
                <p>
                    Browse service opportunities by category such as education, health, and environment.
                </p>
                <a href="/categories">View Categories</a>
            </div>

        </div>

    </section>

</main>

<%- include("partials/footer") %>