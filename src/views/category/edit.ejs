<%- include("../partials/header", { title: title }) %>[cite: 16]

<main class="container">[cite: 16]

  <section class="page-header">[cite: 16]
    <h1>Edit Category</h1>[cite: 16]
    <p>Update category information below.</p>[cite: 16]
  </section>[cite: 16]

  <!-- FORM -->
  <section class="form-container">[cite: 16]

    <form action="/categories/edit/<%= category.id %>" method="POST">[cite: 16]

      <!-- Name -->
      <div class="form-group">[cite: 16]
        <label for="name">Category Name</label>[cite: 16]
        <input
          type="text"
          id="name"
          name="name"
          value="<%= category.name %>"
          required
          minlength="2"
        >[cite: 16]
      </div>[cite: 16]

      <!-- Description -->
      <div class="form-group">[cite: 16]
        <label for="description">Description</label>[cite: 16]
        <textarea
          id="description"
          name="description"
          required
          minlength="5"
        ><%= category.description %></textarea>[cite: 16]
      </div>[cite: 16]

      <!-- Submit -->
      <button type="submit" class="btn">[cite: 16]
        Update Category[cite: 16]
      </button>[cite: 16]

    </form>[cite: 16]

  </section>[cite: 16]

</main>[cite: 16]

<%- include("../partials/footer") %>[cite: 16]