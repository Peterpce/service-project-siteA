<%- include("../partials/header", { title: title }) %>[cite: 14]

<main class="container">[cite: 14]

  <section class="page-header">[cite: 14]
    <h1>Create Category</h1>[cite: 14]
    <p>Add a new service project category.</p>[cite: 14]
  </section>[cite: 14]

  <!-- FORM -->
  <section class="form-container">[cite: 14]

    <form action="/categories/create" method="POST">[cite: 14]

      <!-- Name -->
      <div class="form-group">[cite: 14]
        <label for="name">Category Name</label>[cite: 14]
        <input
          type="text"
          id="name"
          name="name"
          required
          minlength="2"
          placeholder="Enter category name"
        >[cite: 14]
      </div>[cite: 14]

      <!-- Description -->
      <div class="form-group">[cite: 14]
        <label for="description">Description</label>[cite: 14]
        <textarea
          id="description"
          name="description"
          required
          minlength="5"
          placeholder="Enter category description"
        ></textarea>[cite: 14]
      </div>[cite: 14]

      <!-- Submit -->
      <button type="submit" class="btn">[cite: 14]
        Create Category[cite: 14]
      </button>[cite: 14]

    </form>[cite: 14]

  </section>[cite: 14]

</main>[cite: 14]

<%- include("../partials/footer") %>[cite: 14]